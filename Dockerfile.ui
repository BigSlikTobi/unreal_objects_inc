# Unreal Objects admin UI (rule management, decision logs, agent admin)
FROM node:22-slim AS build

RUN apt-get update && apt-get install -y --no-install-recommends git && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone the UI source directly from GitHub (submodule not available in Railway builds)
RUN git clone --depth 1 https://github.com/BigSlikTobi/unreal_objects.git /tmp/uo && \
    cp -r /tmp/uo/ui/* . && \
    rm -rf /tmp/uo

RUN npm ci

# Build-time env vars (Railway sets these before build)
ARG VITE_RULE_ENGINE_BASE_URL
ARG VITE_DECISION_CENTER_BASE_URL
ARG VITE_TOOL_AGENT_BASE_URL

RUN npm run build

# Serve with lightweight static server
FROM node:22-slim
RUN npm install -g serve
WORKDIR /app
COPY --from=build /app/dist ./dist

EXPOSE 5173
CMD sh -c "serve -s dist -l tcp://0.0.0.0:${PORT:-5173}"
