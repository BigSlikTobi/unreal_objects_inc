# Unreal Objects Decision Center (standalone service)
FROM python:3.13-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install unreal_objects directly from GitHub
RUN pip install --no-cache-dir git+https://github.com/BigSlikTobi/unreal_objects.git

EXPOSE 8002

CMD uvicorn decision_center.app:app --host 0.0.0.0 --port ${PORT:-8002}
